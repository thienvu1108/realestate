{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles and project assignments",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["super_admin", "admin", "mod", "user"] 
        },
        "displayName": { "type": "string" },
        "fullName": { "type": "string" },
        "teamName": { "type": "string" },
        "assignedProjects": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of project IDs assigned to Mod"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A real estate project",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Project name" },
        "projectCode": { "type": "string", "description": "Project unique code (e.g., DA-VLP)" },
        "description": { "type": "string", "description": "Project description" },
        "region": { "type": "string", "description": "Region name" },
        "type": { "type": "string", "description": "Project type" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name"]
    },
    "Team": {
      "title": "Team",
      "description": "A marketing team",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Team name" },
        "teamCode": { "type": "string", "description": "Team unique code (e.g., MH01.1)" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name"]
    },
    "BudgetRegistration": {
      "title": "Budget Registration",
      "description": "Monthly budget registration by a team for a project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "teamName": { "type": "string" },
        "month": { "type": "string", "description": "YYYY-MM" },
        "amount": { "type": "number" },
        "verifiedAmount": { "type": "number", "description": "Admin verified actual cost after inspection" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "userEmail": { "type": "string" },
        "assignedUserEmail": { "type": "string", "description": "Email of user assigned to handle this budget" }
      },
      "required": ["projectId", "teamName", "month", "amount"]
    },
    "WeeklyCost": {
      "title": "Weekly Cost",
      "description": "Actual marketing cost spent weekly",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "weekNumber": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "amount": { "type": "number", "description": "Total actual cost for the week" },
        "visaAmount": { "type": "number", "description": "Cost run via company visa card" },
        "digitalAmount": { "type": "number", "description": "Cost run via digital agency" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "userEmail": { "type": "string" },
        "assignedUserEmail": { "type": "string", "description": "Email of user assigned to handle the related budget" }
      },
      "required": ["projectId", "weekNumber", "amount"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "History of changes",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "collection": { "type": "string" },
        "docId": { "type": "string" },
        "data": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userEmail": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "Region": {
      "title": "Region",
      "description": "A geographic region or area",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name"]
    },
    "Type": {
      "title": "Type",
      "description": "A project type (e.g., High-rise, Low-rise)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name"]
    },
    "EfficiencyReport": {
      "title": "Efficiency Report",
      "description": "Actual sales and revenue performance by team and project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "teamId": { "type": "string" },
        "teamName": { "type": "string" },
        "month": { "type": "string", "description": "YYYY-MM" },
        "salesCount": { "type": "number" },
        "revenue": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "createdByEmail": { "type": "string" }
      },
      "required": ["projectId", "teamId", "month"]
    },
    "Setting": {
      "title": "System Settings",
      "description": "Global configuration settings",
      "type": "object",
      "properties": {
        "budgetStartDay": { "type": "number" },
        "budgetEndDay": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    },
    "Acceptance": {
      "title": "Acceptance",
      "description": "Monthly marketing cost acceptance/finalization",
      "type": "object",
      "properties": {
        "month": { "type": "string", "description": "YYYY-MM" },
        "teamId": { "type": "string" },
        "teamCode": { "type": "string" },
        "teamName": { "type": "string" },
        "projectId": { "type": "string" },
        "projectCode": { "type": "string" },
        "projectName": { "type": "string" },
        "facebookCost": { "type": "number" },
        "zaloCost": { "type": "number" },
        "googleCost": { "type": "number" },
        "postingCost": { "type": "number" },
        "otherCost": { "type": "number" },
        "totalCost": { "type": "number" },
        "beforeAcceptanceCost": { "type": "number" },
        "afterAcceptanceCost": { "type": "number" },
        "visaCost": { "type": "number" },
        "digitalCost": { "type": "number" },
        "status": { 
          "type": "string", 
          "enum": ["Trước nghiệm thu", "Đã nghiệm thu"] 
        },
        "acceptanceType": {
          "type": "string",
          "enum": ["Chi phí không đổi", "Chi phí thay đổi"]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["month", "teamId", "projectId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects collection"
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Teams collection"
    },
    "/efficiencyReports/{reportId}": {
      "schema": "EfficiencyReport",
      "description": "Actual sales efficiency reports"
    },
    "/budgets/{budgetId}": {
      "schema": "BudgetRegistration",
      "description": "Monthly budget registrations"
    },
    "/costs/{costId}": {
      "schema": "WeeklyCost",
      "description": "Weekly actual costs"
    },
    "/acceptances/{acceptanceId}": {
      "schema": "Acceptance",
      "description": "Monthly cost acceptance records"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit logs for tracking changes"
    },
    "/regions/{regionId}": {
      "schema": "Region",
      "description": "Geographic regions"
    },
    "/types/{typeId}": {
      "schema": "Type",
      "description": "Project types"
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "Global system settings"
    }
  }
}

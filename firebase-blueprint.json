{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles and project assignments",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["super_admin", "admin", "mod", "user"] 
        },
        "displayName": { "type": "string" },
        "fullName": { "type": "string" },
        "teamName": { "type": "string" },
        "assignedProjects": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of project IDs assigned to Mod"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A real estate project",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Project name" },
        "description": { "type": "string", "description": "Project description" },
        "region": { "type": "string", "description": "Region name" },
        "type": { "type": "string", "description": "Project type" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name"]
    },
    "Team": {
      "title": "Team",
      "description": "A marketing team",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Team name" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name"]
    },
    "BudgetRegistration": {
      "title": "Budget Registration",
      "description": "Monthly budget registration by a team for a project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "teamName": { "type": "string" },
        "month": { "type": "string", "description": "YYYY-MM" },
        "amount": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["projectId", "teamName", "month", "amount"]
    },
    "WeeklyCost": {
      "title": "Weekly Cost",
      "description": "Actual marketing cost spent weekly",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "weekNumber": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["projectId", "weekNumber", "amount"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "History of changes",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "collection": { "type": "string" },
        "docId": { "type": "string" },
        "data": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userEmail": { "type": "string" },
        "userId": { "type": "string" }
      }
    },
    "Region": {
      "title": "Region",
      "description": "A geographic region or area",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name"]
    },
    "Type": {
      "title": "Type",
      "description": "A project type (e.g., High-rise, Low-rise)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Projects collection"
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Teams collection"
    },
    "/budgets/{budgetId}": {
      "schema": "BudgetRegistration",
      "description": "Monthly budget registrations"
    },
    "/costs/{costId}": {
      "schema": "WeeklyCost",
      "description": "Weekly actual costs"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Audit logs for tracking changes"
    },
    "/regions/{regionId}": {
      "schema": "Region",
      "description": "Geographic regions"
    },
    "/types/{typeId}": {
      "schema": "Type",
      "description": "Project types"
    }
  }
}

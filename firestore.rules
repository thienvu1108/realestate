rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Global Safety Net
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Primitive Definition Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (
        request.auth.token.get('email_verified', false) == true || 
        request.auth.token.get('email', '').lower() == "thienvu1108@gmail.com"
      );
    }

    function hasUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').lower() == "thienvu1108@gmail.com" ||
        (hasUserData() && getUserData().get('role', 'user') in ['admin', 'super_admin', 'Admin', 'Super Admin'])
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '').lower() == "thienvu1108@gmail.com" ||
        (hasUserData() && getUserData().get('role', 'user') in ['super_admin', 'Super Admin'])
      );
    }

    function isMod() {
      return isSignedIn() && hasUserData() && getUserData().get('role', 'user') in ['mod', 'moderator', 'Mod', 'Moderator', 'điều phối', 'ĐIỀU PHỐI'];
    }

    function isAccountant() {
      return isSignedIn() && hasUserData() && getUserData().get('role', 'user') in ['accountant', 'Accountant', 'Kế toán', 'KẾ TOÁN'];
    }

    function isGDDA() {
      return isSignedIn() && hasUserData() && getUserData().get('role', 'user') in ['gdda', 'GDDA'];
    }

    function isGDKhoi() {
      return isSignedIn() && hasUserData() && getUserData().get('role', 'user') in ['gd_khoi', 'gdkhoi', 'GĐ Khối', 'Giám đốc Khối', 'Giám đốc liên khối', 'giám đốc liên khối'];
    }

    function isGDKD() {
      return isSignedIn() && hasUserData() && getUserData().get('role', 'user') in ['gdkd', 'GĐKD', 'Giám đốc Kinh doanh', 'giám đốc kinh doanh'];
    }

    function getGDKhoiPrefix() {
      return get(/databases/$(database)/documents/blocks/$(getUserData().get('assignedBlock', ''))).data.get('teamPrefix', '_NONE_');
    }

    function isMatchBlockPrefix(teamId) {
      return teamId != '' && 
             exists(/databases/$(database)/documents/teams/$(teamId)) && 
             get(/databases/$(database)/documents/teams/$(teamId)).data.get('teamCode', '_NONE_').matches('^' + getGDKhoiPrefix() + '.*');
    }

    function isInternalStaff() {
      return isAdmin() || isMod() || isAccountant() || isGDDA() || isGDKhoi() || isGDKD();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Return the incoming document fields map
    function incoming() {
      return request.resource.data;
    }

    // Return the existing document fields map
    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Return true if the given string is a valid email
    function isValidEmail(email) {
      return email is string && email.size() <= 200 && email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }

    // ===============================================================
    // Internal / Connection Test
    // ===============================================================
    match /_internal_/connection_test {
      allow read: if isSignedIn();
    }

    match /test/connection {
      allow read: if isSignedIn();
    }

    // ===============================================================
    // Users
    // ===============================================================
    function isValidUser(data) {
      return isValidEmail(data.email) &&
             (!('role' in data) || data.role is string);
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isInternalStaff() || isGDKD() || isGDKhoi();
      allow list: if isAdmin() || isAccountant() || isGDKD() || isGDKhoi();
      allow create: if (isOwner(userId) && isValidUser(incoming())) || 
                       (isGDKD() && incoming().get('teamName', '') == getUserData().get('teamName', '_NONE_'));
      allow update: if (
        (isOwner(userId) && 
         incoming().role == existing().role && 
         !('assignedProjects' in incoming().diff(existing()).affectedKeys()) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'teamName', 'displayName', 'onboardingTeam', 'updatedAt'])
        ) || 
        isAdmin() || isAccountant() ||
        (isGDKD() && existing().get('teamName', '') == getUserData().get('teamName', '_NONE_') && incoming().get('teamName', '') == getUserData().get('teamName', '_NONE_'))
      );
      allow delete: if isAdmin() || isAccountant() || 
                       (isGDKD() && existing().get('teamName', '') == getUserData().get('teamName', '_NONE_'));
    }

    // ===============================================================
    // Projects
    // ===============================================================
    function isValidProject(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200;
    }

    match /projects/{projectId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isAdmin() || isAccountant();
      allow update: if isAdmin() || isAccountant();
      allow delete: if isAdmin() || isAccountant();
    }

    // ===============================================================
    // Teams
    // ===============================================================
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isAccountant() || isGDKhoi();
      allow update: if isAdmin() || isAccountant() || isGDKhoi();
      allow delete: if isAdmin() || isAccountant() || isGDKhoi();
    }

    // ===============================================================
    // Blocks
    // ===============================================================
    function isValidBlock(data) {
      return data.name is string && data.name.size() > 0 &&
             data.blockCode is string && data.blockCode.size() > 0 &&
             data.teamPrefix is string && data.teamPrefix.size() > 0;
    }

    match /blocks/{blockId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || isAccountant() || isGDKhoi()) && isValidBlock(incoming());
      allow update: if (isAdmin() || isAccountant() || isGDKhoi()) && isValidBlock(incoming());
      allow delete: if isAdmin() || isAccountant();
    }

    // ===============================================================
    // Budgets
    // ===============================================================
    function isValidBudget(data) {
      return data.projectId is string && data.month is string && data.amount is number;
    }

    match /budgets/{budgetId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && isValidBudget(incoming()) && (
        incoming().createdBy == request.auth.uid ||
        (isGDKD() && incoming().get('teamName', '') == getUserData().get('teamName', '_NONE_')) ||
        (isGDKhoi() && isMatchBlockPrefix(incoming().get('teamId', '')))
      );
      
      allow update: if (
        isAdmin() || isAccountant() || 
        resource.data.createdBy == request.auth.uid || 
        (resource.data.assignedUserEmail.lower() == request.auth.token.email.lower()) ||
        (isGDKD() && resource.data.get('teamName', '') == getUserData().get('teamName', '_NONE_')) ||
        (isGDKhoi() && isMatchBlockPrefix(resource.data.get('teamId', '')))
      ) && isValidBudget(incoming());
      
      allow delete: if isAdmin() || isAccountant() || 
                       (isGDKD() && resource.data.get('teamName', '') == getUserData().get('teamName', '_NONE_')) ||
                       (isGDKhoi() && isMatchBlockPrefix(resource.data.get('teamId', '')));
    }

    // ===============================================================
    // Costs
    // ===============================================================
    match /costs/{costId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && (
        incoming().createdBy == request.auth.uid ||
        (isGDKD() && incoming().get('teamName', '') == getUserData().get('teamName', '_NONE_')) ||
        (isGDKhoi() && isMatchBlockPrefix(incoming().get('teamId', '')))
      );
      
      allow update: if (
        isAdmin() || isAccountant() || 
        resource.data.createdBy == request.auth.uid || 
        (resource.data.assignedUserEmail.lower() == request.auth.token.email.lower()) ||
        (isGDKD() && resource.data.get('teamName', '') == getUserData().get('teamName', '_NONE_')) ||
        (isGDKhoi() && isMatchBlockPrefix(resource.data.get('teamId', '')))
      );
      
      allow delete: if isAdmin() || isAccountant() || 
                       (isGDKD() && resource.data.get('teamName', '') == getUserData().get('teamName', '_NONE_')) ||
                       (isGDKhoi() && isMatchBlockPrefix(resource.data.get('teamId', '')));
    }

    // ===============================================================
    // Support Requests
    // ===============================================================
    match /supportRequests/{requestId} {
      allow read: if isAdmin() || isMod() || isAccountant() || resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin() || isMod() || isAccountant() || resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || isAccountant();
    }

    // ===============================================================
    // Audit Logs
    // ===============================================================
    match /auditLogs/{logId} {
      allow get: if isInternalStaff();
      allow list: if isInternalStaff();
      allow create: if isSignedIn();
    }

    // ===============================================================
    // Regions & Types
    // ===============================================================
    match /regions/{regionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAccountant();
    }

    match /types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAccountant();
    }

    // ===============================================================
    // Efficiency Reports
    // ===============================================================
    match /efficiencyReports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isInternalStaff();
    }

    // ===============================================================
    // Acceptances & Final Acceptances
    // ===============================================================
    match /acceptances/{acceptanceId} {
      allow read: if isInternalStaff();
      allow create: if isInternalStaff();
      allow update: if isInternalStaff();
      allow delete: if isAdmin() || isAccountant();
    }

    match /finalAcceptances/{finalId} {
      allow read: if isInternalStaff();
      allow create: if isAdmin() || isMod() || isAccountant();
      allow update: if isAdmin() || isMod() || isAccountant();
      allow delete: if isAdmin() || isAccountant();
    }

    // ===============================================================
    // Document Processing
    // ===============================================================
    match /docProcessing/{docId} {
      allow read: if isInternalStaff();
      allow write: if isInternalStaff();
    }

    // ===============================================================
    // Settings
    // ===============================================================
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isAccountant();
    }

    // ===============================================================
    // Role Permissions
    // ===============================================================
    match /rolePermissions/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
